{
    auto_https off
    admin off
}

localhost {
    tls /etc/caddy/certs/localhost.pem /etc/caddy/certs/localhost-key.pem

    handle /health {
        respond "ok" 200
    }

    # Padhanam API (P2/S7). Path-based routing under /api/* strips the
    # prefix before reverse-proxying so the upstream FastAPI app sees
    # /health and /inference/completions directly. Path routing is the
    # right choice for an API surface — no Next.js basePath issue (the
    # constraint that pushed Langfuse to a subdomain in S4 doesn't
    # apply here). UI services keep going on subdomains; APIs on
    # paths is the consistent pattern from S4.
    handle_path /api/* {
        reverse_proxy padhanam-api:8000 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
            header_up X-Forwarded-For {remote}
        }
    }

    handle {
        respond "Padhanam dev proxy. No backends configured yet." 503
    }
}

# Langfuse on its own subdomain. Path-based routing under /langfuse/* doesn't
# work because Langfuse is a Next.js app whose asset URLs (/_next/*) only
# respect a basePath set at build time (NEXT_PUBLIC_BASE_PATH). Subdomain
# serving keeps the upstream image pinned to digest and sets the pattern for
# future UI services (Keycloak as auth.localhost, Padhanam app UI, etc.).
# *.localhost resolves to 127.0.0.1 on macOS without /etc/hosts changes.
langfuse.localhost {
    tls /etc/caddy/certs/localhost.pem /etc/caddy/certs/localhost-key.pem

    reverse_proxy langfuse-web:3000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote}
    }
}
