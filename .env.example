# Vadakkan environment template
#
# Copy to .env and fill in values. Never commit .env.
# Variables are added per package as services are introduced (see D11).

# Postgres (P1 application instance)
POSTGRES_USER=vadakkan
POSTGRES_PASSWORD=vadakkan
POSTGRES_DB=vadakkan

# Postgres tenancy instances (P3/S9). The control-plane Postgres hosts the
# tenant registry per D33; postgres-tenant-a and postgres-tenant-b are the
# two test-set tenant data planes per D32. The credentials below are local
# defaults; the registry adapter at S10 will use these to bootstrap the
# registry rows, after which routing reads encrypted credentials from the
# registry rather than these env vars (D21).
POSTGRES_CONTROL_PLANE_USER=control_plane
POSTGRES_CONTROL_PLANE_PASSWORD=control_plane
POSTGRES_CONTROL_PLANE_DB=control_plane

POSTGRES_TENANT_A_USER=tenant_a
POSTGRES_TENANT_A_PASSWORD=tenant_a
POSTGRES_TENANT_A_DB=tenant_a

POSTGRES_TENANT_B_USER=tenant_b
POSTGRES_TENANT_B_PASSWORD=tenant_b
POSTGRES_TENANT_B_DB=tenant_b

# Redis
# (no host port binding — only Caddy:443 binds the host. Use `make psql`
# for direct shell access, or attach via `docker compose exec`.)

# Langfuse: metadata Postgres (separate instance from Vadakkan's; Langfuse owns its schema)
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=replace-me
LANGFUSE_DB_NAME=langfuse

# Langfuse: ClickHouse (trace data plane in Langfuse 3)
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=replace-me
CLICKHOUSE_DB=langfuse

# Langfuse: MinIO (S3-compatible event/media object store)
MINIO_ROOT_USER=langfuse
MINIO_ROOT_PASSWORD=replace-me

# Langfuse: secrets (generate via openssl: rand -base64 32 for SECRET/SALT, rand -hex 32 for ENCRYPTION_KEY)
LANGFUSE_NEXTAUTH_SECRET=replace-me
LANGFUSE_SALT=replace-me
LANGFUSE_ENCRYPTION_KEY=replace-me-64-hex-chars

# Langfuse: headless org/project/user/key bootstrap (LANGFUSE_INIT_*)
LANGFUSE_INIT_ORG_ID=vadakkan
LANGFUSE_INIT_ORG_NAME=vadakkan
LANGFUSE_INIT_PROJECT_ID=vadakkan-dev
LANGFUSE_INIT_PROJECT_NAME=vadakkan-dev
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-replace-me
LANGFUSE_INIT_USER_EMAIL=admin@vadakkan.local
LANGFUSE_INIT_USER_NAME=Vadakkan Admin
LANGFUSE_INIT_USER_PASSWORD=replace-me

# LiteLLM proxy: master key (P2/S6)
# Authenticates clients calling the LiteLLM /v1/* endpoints. Must start with
# `sk-`. Generate via `openssl rand -hex 32 | sed 's/^/sk-/'` or any
# high-entropy random string. The OTel auth header for trace export to
# Langfuse is *derived* from the LANGFUSE_INIT_PROJECT_*_KEY values above
# (see ops/derive_env.py); no separate variable lives here.
LITELLM_MASTER_KEY=sk-replace-me-must-start-with-sk
